---
import '../styles/global.css';
import { db } from '../lib/db';
import { changelog } from '../lib/schema';
import { desc, eq } from 'drizzle-orm';

let versions = [];

try {
  versions = await db
    .select()
    .from(changelog)
    .where(eq(changelog.published, true))
    .orderBy(desc(changelog.sortOrder));
} catch (error) {
  console.error('Error loading changelog:', error);
  // Fallback data si falla la conexión
  versions = [
    {
      version: "2.6.0",
      date: new Date("2026-03-28"),
      title: "Optimización de Rendimiento",
      improvements: [
        "Carga 40% más rápida en vista móvil de reservaciones",
        "Búsqueda ampliada en personal: ahora incluye teléfono y rol",
        "Reducción de 20-23% en tamaño de páginas principales"
      ],
      fixes: [
        "Corregido solapamiento en registro inicial desde móvil",
        "Solucionado error de colores en configuración de categorías"
      ]
    }
  ];
}

// Format dates
const formattedVersions = versions.map(v => ({
  ...v,
  dateFormatted: new Date(v.date).toLocaleDateString('es-ES', { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  })
}));
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Changelog - Flip</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans antialiased bg-white text-gray-900">
    
    <!-- Navigation -->
    <header class="fixed top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-100">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <span class="text-xl font-semibold">Flip</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
          <a href="/" class="hover:text-blue-600 transition">Inicio</a>
          <a href="/pricing" class="hover:text-blue-600 transition">Precios</a>
          <a href="/changelog" class="text-blue-600">Novedades</a>
        </nav>

        <a href="https://flip-v2-web.vercel.app/" class="px-6 py-2 bg-blue-600 text-white text-sm font-medium rounded-full hover:bg-blue-700 transition">
          Abrir App
        </a>
      </div>
    </header>

    <main class="pt-32 pb-20">
      
      <!-- Header -->
      <section class="px-6 mb-20">
        <div class="container mx-auto max-w-5xl">
          <div class="flex items-end justify-between border-b border-gray-200 pb-8">
            <div>
              <h1 class="text-6xl md:text-7xl font-light tracking-tight mb-4">
                Flip<br/>
                <span class="font-semibold">Changelog</span>
              </h1>
            </div>
            <div class="hidden md:flex items-center gap-3 text-sm text-gray-500">
              <a href="https://github.com/YasmaniJob/flip" class="hover:text-blue-600 transition">Ver en GitHub</a>
              <a href="https://twitter.com/flip" class="hover:text-blue-600 transition">Seguir en X</a>
            </div>
          </div>
        </div>
      </section>

      <!-- Info Banner -->
      <section class="px-6 mb-16">
        <div class="container mx-auto max-w-5xl">
          <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgb(37, 99, 235)" stroke-width="2" class="flex-shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <p class="text-sm text-gray-700">
              Las actualizaciones se despliegan automáticamente. Todas las mejoras están disponibles inmediatamente para todos los usuarios.
            </p>
          </div>
        </div>
      </section>

      <!-- Versions List -->
      <section class="px-6">
        <div class="container mx-auto max-w-5xl space-y-16">
          
          {formattedVersions.map((v) => (
            <article class="border-l-2 border-gray-200 pl-8 hover:border-blue-600 transition-colors">
              
              <div class="flex items-baseline gap-6 mb-6">
                <span class="text-sm font-mono text-blue-600 font-semibold">{v.version}</span>
                <span class="text-sm text-gray-500">{v.dateFormatted}</span>
              </div>

              <h2 class="text-4xl font-semibold tracking-tight mb-8">{v.title}</h2>

              {v.improvements && v.improvements.length > 0 && (
                <div class="mb-8">
                  <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Mejoras ({v.improvements.length})</h3>
                  <ul class="space-y-3">
                    {v.improvements.map((item) => (
                      <li class="flex items-start gap-3 text-gray-700">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(34, 197, 94)" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                        <span class="leading-relaxed">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {v.fixes && v.fixes.length > 0 && (
                <div>
                  <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Correcciones ({v.fixes.length})</h3>
                  <ul class="space-y-3">
                    {v.fixes.map((item) => (
                      <li class="flex items-start gap-3 text-gray-700">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(239, 68, 68)" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
                        <span class="leading-relaxed">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

            </article>
          ))}

        </div>
      </section>

    </main>

    <footer class="py-12 px-6 border-t border-gray-100 mt-32">
      <div class="container mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          <span>© 2026 Flip</span>
        </div>
        <div class="flex gap-8">
          <a href="#" class="hover:text-blue-600 transition">Twitter</a>
          <a href="#" class="hover:text-blue-600 transition">GitHub</a>
          <a href="#" class="hover:text-blue-600 transition">Documentación</a>
        </div>
      </div>
    </footer>

  </body>
</html>
