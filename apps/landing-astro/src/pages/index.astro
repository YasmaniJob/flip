---
import '../styles/global.css';
const appUrl = "https://flip-v2-web.vercel.app/";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Flip - Gestión Inteligente de Recursos Educativos</title>
    <meta name="description" content="Optimiza el inventario, préstamos y reuniones de tu institución educativa con Flip." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans antialiased bg-white text-gray-900">
    
    <!-- Navigation -->
    <header class="fixed top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-100">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <span class="text-xl font-semibold">Flip</span>
        </div>
        
        <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
          <a href="#features" class="hover:text-blue-600 transition">Características</a>
          <a href="#cases" class="hover:text-blue-600 transition">Casos de Uso</a>
          <a href="/pricing" class="hover:text-blue-600 transition">Precios</a>
          <a href="/changelog" class="hover:text-blue-600 transition">Changelog</a>
        </nav>

        <a href={appUrl} class="px-6 py-2 bg-blue-600 text-white text-sm font-medium rounded-full hover:bg-blue-700 transition">
          Abrir App
        </a>
      </div>
    </header>

    <main class="pt-16">
      
      <!-- Hero Section - Antigravity Style -->
      <section class="min-h-screen flex flex-col items-center justify-center px-6 py-32 relative overflow-hidden">
        
        <!-- Animated Background Icons -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-5">
          <div class="absolute top-20 left-10 animate-float-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/></svg>
          </div>
          <div class="absolute top-40 right-20 animate-float-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
          </div>
          <div class="absolute bottom-40 left-1/4 animate-float-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="45" height="45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M2 12h20"/></svg>
          </div>
          <div class="absolute top-1/3 right-1/4 animate-float-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
          </div>
        </div>

        <div class="max-w-5xl mx-auto text-center relative z-10">
          <!-- Cursor Blinking -->
          <div class="inline-block mb-8">
            <div class="w-1 h-16 bg-blue-600 animate-blink"></div>
          </div>

          <h1 class="text-7xl md:text-9xl font-light tracking-tight mb-8 leading-none">
            Experience liftoff<br/>
            <span class="font-semibold">with Flip</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-gray-600 mb-16 max-w-3xl mx-auto font-light">
            La plataforma de gestión educativa diseñada para coordinadores que exigen eficiencia absoluta
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
            <a href={appUrl} class="px-8 py-4 bg-blue-600 text-white font-medium rounded-full hover:bg-blue-700 transition text-base">
              Abrir Flip
            </a>
            <a href="#cases" class="px-8 py-4 border border-gray-300 text-gray-700 font-medium rounded-full hover:border-gray-400 transition text-base flex items-center gap-2">
              Explorar casos de uso
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5 3 19 12 5 21 5 3"/></svg>
            </a>
          </div>

          <!-- Floating Icons Animation -->
          <div class="mt-24 flex items-center justify-center gap-4 flex-wrap opacity-40">
            <span class="text-sm font-mono animate-slide-right">code</span>
            <span class="text-sm font-mono animate-slide-left">refresh</span>
            <span class="text-sm font-mono animate-slide-right">dashboard</span>
            <span class="text-sm font-mono animate-slide-left">search</span>
            <span class="text-sm font-mono animate-slide-right">folder</span>
            <span class="text-sm font-mono animate-slide-left">terminal</span>
            <span class="text-sm font-mono animate-slide-right">data</span>
            <span class="text-sm font-mono animate-slide-left">check</span>
          </div>
        </div>
      </section>

      <!-- Core Features - Clean Grid -->
      <section id="features" class="py-32 px-6 bg-gray-50">
        <div class="container mx-auto max-w-7xl">
          
          <div class="grid md:grid-cols-2 gap-24 items-start">
            
            <!-- Feature 1 -->
            <div class="space-y-6">
              <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              </div>
              <h3 class="text-4xl font-semibold tracking-tight">Inventario Centralizado</h3>
              <p class="text-lg text-gray-600 leading-relaxed font-light">
                Gestiona todos los recursos de tu institución desde una interfaz unificada. Control de stock, mantenimiento y trazabilidad completa.
              </p>
            </div>

            <!-- Feature 2 -->
            <div class="space-y-6">
              <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              </div>
              <h3 class="text-4xl font-semibold tracking-tight">Reservaciones Inteligentes</h3>
              <p class="text-lg text-gray-600 leading-relaxed font-light">
                Sistema de reservas que previene conflictos automáticamente. Calendario visual optimizado para móvil y desktop.
              </p>
            </div>

            <!-- Feature 3 -->
            <div class="space-y-6">
              <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <h3 class="text-4xl font-semibold tracking-tight">Gestión de Personal</h3>
              <p class="text-lg text-gray-600 leading-relaxed font-light">
                Administra docentes, coordinadores y personal. Búsqueda avanzada por múltiples criterios y roles personalizables.
              </p>
            </div>

            <!-- Feature 4 -->
            <div class="space-y-6">
              <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>
              </div>
              <h3 class="text-4xl font-semibold tracking-tight">Analytics en Tiempo Real</h3>
              <p class="text-lg text-gray-600 leading-relaxed font-light">
                Métricas y reportes automáticos. Visualiza el uso de recursos, tendencias y toma decisiones basadas en datos.
              </p>
            </div>

          </div>
        </div>
      </section>


      <!-- Use Cases Section -->
      <section id="cases" class="py-32 px-6">
        <div class="container mx-auto max-w-7xl">
          
          <div class="text-center mb-20">
            <h2 class="text-5xl md:text-7xl font-light tracking-tight mb-6">
              Built for <span class="font-semibold">educators</span><br/>
              for the digital era
            </h2>
            <p class="text-xl text-gray-600 font-light max-w-3xl mx-auto">
              Flip está diseñado para instituciones educativas que buscan modernizar su gestión operativa
            </p>
          </div>

          <!-- Case Cards -->
          <div class="grid md:grid-cols-3 gap-8">
            
            <div class="group relative bg-white border border-gray-200 rounded-3xl overflow-hidden hover:shadow-2xl transition-all duration-500">
              <div class="aspect-video bg-gradient-to-br from-blue-50 to-blue-100 relative overflow-hidden">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgb(37, 99, 235)" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              </div>
              <div class="p-8">
                <div class="inline-block w-1 h-8 bg-blue-600 mb-4 animate-blink"></div>
                <h3 class="text-2xl font-semibold mb-3">Coordinador Académico</h3>
                <p class="text-gray-600 leading-relaxed font-light">
                  Gestiona aulas, equipos y reservaciones desde un dashboard centralizado
                </p>
                <div class="mt-6 flex items-center gap-2 text-blue-600 font-medium text-sm group-hover:gap-4 transition-all">
                  <span>Ver caso</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5 3 19 12 5 21 5 3"/></svg>
                </div>
              </div>
            </div>

            <div class="group relative bg-white border border-gray-200 rounded-3xl overflow-hidden hover:shadow-2xl transition-all duration-500">
              <div class="aspect-video bg-gradient-to-br from-purple-50 to-purple-100 relative overflow-hidden">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgb(147, 51, 234)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              </div>
              <div class="p-8">
                <div class="inline-block w-1 h-8 bg-purple-600 mb-4 animate-blink"></div>
                <h3 class="text-2xl font-semibold mb-3">Docente</h3>
                <p class="text-gray-600 leading-relaxed font-light">
                  Solicita préstamos de equipos y reserva espacios en segundos desde tu móvil
                </p>
                <div class="mt-6 flex items-center gap-2 text-purple-600 font-medium text-sm group-hover:gap-4 transition-all">
                  <span>Ver caso</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5 3 19 12 5 21 5 3"/></svg>
                </div>
              </div>
            </div>

            <div class="group relative bg-white border border-gray-200 rounded-3xl overflow-hidden hover:shadow-2xl transition-all duration-500">
              <div class="aspect-video bg-gradient-to-br from-green-50 to-green-100 relative overflow-hidden">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgb(34, 197, 94)" stroke-width="1.5"><path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Z"/><path d="m3 9 2.45-4.9A2 2 0 0 1 7.24 3h9.52a2 2 0 0 1 1.8 1.1L21 9"/><path d="M12 3v6"/></svg>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              </div>
              <div class="p-8">
                <div class="inline-block w-1 h-8 bg-green-600 mb-4 animate-blink"></div>
                <h3 class="text-2xl font-semibold mb-3">Director</h3>
                <p class="text-gray-600 leading-relaxed font-light">
                  Supervisa operaciones, genera reportes y optimiza el uso de recursos institucionales
                </p>
                <div class="mt-6 flex items-center gap-2 text-green-600 font-medium text-sm group-hover:gap-4 transition-all">
                  <span>Ver caso</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5 3 19 12 5 21 5 3"/></svg>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- Product Preview -->
      <section class="py-32 px-6">
        <div class="container mx-auto max-w-6xl">
          <div class="relative group">
            <div class="aspect-video bg-gradient-to-br from-gray-100 to-gray-200 rounded-3xl overflow-hidden border border-gray-200 shadow-2xl">
              <div class="p-8 h-full flex flex-col">
                <!-- Browser Chrome -->
                <div class="flex items-center gap-2 mb-6">
                  <div class="w-3 h-3 rounded-full bg-red-400"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                  <div class="w-3 h-3 rounded-full bg-green-400"></div>
                </div>
                
                <!-- Dashboard Mockup -->
                <div class="flex-1 bg-white rounded-2xl shadow-lg p-6 grid grid-cols-12 gap-4">
                  <div class="col-span-3 bg-gray-100 rounded-xl"></div>
                  <div class="col-span-9 space-y-4">
                    <div class="h-16 bg-blue-50 rounded-xl border border-blue-200"></div>
                    <div class="grid grid-cols-3 gap-4">
                      <div class="h-24 bg-gray-50 rounded-xl"></div>
                      <div class="h-24 bg-gray-50 rounded-xl"></div>
                      <div class="h-24 bg-gray-50 rounded-xl"></div>
                    </div>
                    <div class="h-32 bg-gray-50 rounded-xl"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>


      <!-- Pricing Section -->
      <section id="pricing" class="py-32 px-6 bg-gray-50">
        <div class="container mx-auto max-w-7xl">
          
          <div class="text-center mb-20">
            <h2 class="text-5xl md:text-7xl font-light tracking-tight mb-6">
              Available at <span class="font-semibold">no charge</span>
            </h2>
            <p class="text-xl text-gray-600 font-light">Para instituciones educativas</p>
          </div>

          <div class="max-w-2xl mx-auto bg-white border border-gray-200 rounded-3xl p-12 text-center">
            <div class="mb-8">
              <div class="text-6xl font-light mb-2">$0</div>
              <div class="text-gray-600 font-light">Gratis para siempre</div>
            </div>
            
            <ul class="space-y-4 mb-10 text-left">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgb(34, 197, 94)" stroke-width="2.5" class="mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-gray-700">Inventario ilimitado</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgb(34, 197, 94)" stroke-width="2.5" class="mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-gray-700">Reservaciones sin límite</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgb(34, 197, 94)" stroke-width="2.5" class="mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-gray-700">Usuarios ilimitados</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgb(34, 197, 94)" stroke-width="2.5" class="mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-gray-700">Soporte por email</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgb(34, 197, 94)" stroke-width="2.5" class="mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-gray-700">Actualizaciones automáticas</span>
              </li>
            </ul>

            <a href={appUrl} class="inline-block w-full px-8 py-4 bg-blue-600 text-white font-medium rounded-full hover:bg-blue-700 transition">
              Comenzar ahora
            </a>
          </div>

        </div>
      </section>

      <!-- Final CTA -->
      <section class="py-40 px-6 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-50/50 to-transparent pointer-events-none"></div>
        
        <div class="container mx-auto max-w-4xl relative z-10">
          <div class="inline-block mb-8">
            <div class="w-1 h-20 bg-blue-600 animate-blink"></div>
          </div>
          
          <h2 class="text-6xl md:text-8xl font-light tracking-tight mb-12 leading-none">
            Achieve new<br/>
            <span class="font-semibold">heights</span>
          </h2>
          
          <a href={appUrl} class="inline-block px-12 py-5 bg-blue-600 text-white text-lg font-medium rounded-full hover:bg-blue-700 hover:scale-105 transition-all shadow-xl">
            Abrir Flip
          </a>
        </div>
      </section>

    </main>

    <footer class="py-12 px-6 border-t border-gray-100">
      <div class="container mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          <span>© 2026 Flip</span>
        </div>
        <div class="flex gap-8">
          <a href="#" class="hover:text-blue-600 transition">Twitter</a>
          <a href="#" class="hover:text-blue-600 transition">GitHub</a>
          <a href="#" class="hover:text-blue-600 transition">Documentación</a>
        </div>
      </div>
    </footer>

  </body>
</html>
