  <script>
    (function () {
      const line1El = document.getElementById('typewriter-line1');
      const line2El = document.getElementById('typewriter-line2');
      const cursorEl = document.getElementById('typewriter-cursor') as HTMLElement | null;

      if (!line1El || !line2El || !cursorEl) return;

      const line1 = 'Gestión digital';
      const line2 = 'para tu AIP';
      const speed = 42; // ms per character

      let i = 0;
      let phase = 1; // 1 = typing line1, 2 = typing line2

      // Show cursor immediately
      cursorEl.style.display = 'inline-block';

      function typeNext() {
        if (phase === 1) {
          if (i < line1.length) {
            line1El!.textContent += line1[i++];
            setTimeout(typeNext, speed);
          } else {
            // Pause briefly before typing line 2
            phase = 2;
            i = 0;
            setTimeout(typeNext, 220);
          }
        } else {
          if (i < line2.length) {
            line2El!.textContent += line2[i++];
            setTimeout(typeNext, speed);
          }
          // Cursor stays blinking after done
        }
      }

      // Small initial delay so page renders first
      setTimeout(typeNext, 300);
    })();
  </script>
