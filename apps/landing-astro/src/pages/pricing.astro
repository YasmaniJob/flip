---
import '../styles/global.css';

const plans = [
  {
    name: "Básico",
    price: "$0",
    period: "Gratis para siempre",
    description: "Perfecto para instituciones pequeñas que están comenzando",
    features: [
      "Hasta 100 recursos en inventario",
      "Reservaciones ilimitadas",
      "3 usuarios administradores",
      "Soporte por email",
      "Actualizaciones automáticas"
    ],
    cta: "Comenzar gratis",
    highlighted: false
  },
  {
    name: "Profesional",
    price: "$49",
    period: "por mes",
    description: "Para instituciones que necesitan funcionalidades avanzadas",
    features: [
      "Recursos ilimitados",
      "Usuarios ilimitados",
      "Módulo de préstamos completo",
      "Analytics y reportes avanzados",
      "Gestión de reuniones y acuerdos",
      "Multi-institución",
      "Soporte prioritario 24/7",
      "Capacitación incluida"
    ],
    cta: "Comenzar prueba",
    highlighted: true
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "contactar ventas",
    description: "Soluciones personalizadas para redes educativas grandes",
    features: [
      "Todo lo de Profesional",
      "Multi-sede ilimitado",
      "API REST completa",
      "SSO y autenticación personalizada",
      "SLA garantizado",
      "Gerente de cuenta dedicado",
      "Implementación asistida",
      "Personalización de marca"
    ],
    cta: "Contactar ventas",
    highlighted: false
  }
];
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Precios - Flip</title>
    <meta name="description" content="Planes y precios de Flip. Comienza gratis o elige el plan que mejor se adapte a tu institución." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans antialiased bg-white text-gray-900">
    
    <!-- Navigation -->
    <header class="fixed top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-100">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <span class="text-xl font-semibold">Flip</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
          <a href="/" class="hover:text-blue-600 transition">Inicio</a>
          <a href="/pricing" class="text-blue-600">Precios</a>
          <a href="/changelog" class="hover:text-blue-600 transition">Changelog</a>
        </nav>

        <a href="https://flip-v2-web.vercel.app/" class="px-6 py-2 bg-blue-600 text-white text-sm font-medium rounded-full hover:bg-blue-700 transition">
          Abrir App
        </a>
      </div>
    </header>

    <main class="pt-32 pb-20">
      
      <!-- Header -->
      <section class="px-6 mb-20 text-center">
        <div class="container mx-auto max-w-4xl">
          <div class="inline-block mb-8">
            <div class="w-1 h-16 bg-blue-600 animate-blink"></div>
          </div>
          
          <h1 class="text-6xl md:text-8xl font-light tracking-tight mb-6 leading-none">
            Simple <span class="font-semibold">pricing</span>
          </h1>
          
          <p class="text-xl text-gray-600 font-light max-w-2xl mx-auto">
            Elige el plan que mejor se adapte a las necesidades de tu institución educativa
          </p>
        </div>
      </section>

      <!-- Pricing Cards -->
      <section class="px-6">
        <div class="container mx-auto max-w-7xl">
          <div class="grid md:grid-cols-3 gap-8">
            
            {plans.map((plan) => (
              <div class={`relative bg-white rounded-3xl overflow-hidden transition-all duration-500 ${
                plan.highlighted 
                  ? 'border-2 border-blue-600 shadow-2xl scale-105' 
                  : 'border border-gray-200 hover:shadow-xl'
              }`}>
                
                {plan.highlighted && (
                  <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-blue-400 via-blue-600 to-blue-400"></div>
                )}

                <div class="p-10">
                  
                  <div class="mb-8">
                    <h3 class="text-2xl font-semibold mb-2">{plan.name}</h3>
                    <div class="flex items-baseline gap-2 mb-2">
                      <span class="text-5xl font-light">{plan.price}</span>
                      {plan.price !== "Custom" && <span class="text-gray-500 text-sm">{plan.period}</span>}
                    </div>
                    {plan.price === "Custom" && (
                      <span class="text-gray-500 text-sm">{plan.period}</span>
                    )}
                  </div>

                  <p class="text-gray-600 mb-8 leading-relaxed font-light">
                    {plan.description}
                  </p>

                  <ul class="space-y-4 mb-10">
                    {plan.features.map((feature) => (
                      <li class="flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(34, 197, 94)" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                        <span class="text-gray-700 text-sm leading-relaxed">{feature}</span>
                      </li>
                    ))}
                  </ul>

                  <a 
                    href={plan.highlighted ? "https://flip-v2-web.vercel.app/" : "#"}
                    class={`block w-full py-4 text-center font-medium rounded-full transition-all ${
                      plan.highlighted
                        ? 'bg-blue-600 text-white hover:bg-blue-700'
                        : 'border border-gray-300 text-gray-700 hover:border-gray-400 hover:bg-gray-50'
                    }`}
                  >
                    {plan.cta}
                  </a>

                </div>
              </div>
            ))}

          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="px-6 mt-32">
        <div class="container mx-auto max-w-4xl">
          
          <h2 class="text-4xl font-semibold tracking-tight mb-12 text-center">Preguntas frecuentes</h2>

          <div class="space-y-8">
            
            <div class="border-b border-gray-200 pb-8">
              <h3 class="text-xl font-semibold mb-3">¿Puedo cambiar de plan en cualquier momento?</h3>
              <p class="text-gray-600 leading-relaxed font-light">
                Sí, puedes actualizar o degradar tu plan en cualquier momento. Los cambios se aplican inmediatamente y se prorratean según corresponda.
              </p>
            </div>

            <div class="border-b border-gray-200 pb-8">
              <h3 class="text-xl font-semibold mb-3">¿Qué métodos de pago aceptan?</h3>
              <p class="text-gray-600 leading-relaxed font-light">
                Aceptamos tarjetas de crédito/débito (Visa, Mastercard, American Express) y transferencias bancarias para planes Enterprise.
              </p>
            </div>

            <div class="border-b border-gray-200 pb-8">
              <h3 class="text-xl font-semibold mb-3">¿Ofrecen descuentos para múltiples instituciones?</h3>
              <p class="text-gray-600 leading-relaxed font-light">
                Sí, ofrecemos descuentos especiales para redes educativas con múltiples sedes. Contacta a nuestro equipo de ventas para más información.
              </p>
            </div>

            <div class="pb-8">
              <h3 class="text-xl font-semibold mb-3">¿Hay período de prueba?</h3>
              <p class="text-gray-600 leading-relaxed font-light">
                El plan Básico es gratis para siempre. Para el plan Profesional, ofrecemos 14 días de prueba sin necesidad de tarjeta de crédito.
              </p>
            </div>

          </div>
        </div>
      </section>

    </main>

    <footer class="py-12 px-6 border-t border-gray-100 mt-32">
      <div class="container mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          <span>© 2026 Flip</span>
        </div>
        <div class="flex gap-8">
          <a href="#" class="hover:text-blue-600 transition">Twitter</a>
          <a href="#" class="hover:text-blue-600 transition">GitHub</a>
          <a href="#" class="hover:text-blue-600 transition">Documentación</a>
        </div>
      </div>
    </footer>

  </body>
</html>
