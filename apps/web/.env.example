# =============================================================================
# FLIP V2 - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to version control

# -----------------------------------------------------------------------------
# Application URL
# -----------------------------------------------------------------------------
# REQUIRED: The base URL of your application
# Development: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database - Neon (PostgreSQL)
# -----------------------------------------------------------------------------
# REQUIRED: PostgreSQL connection string for transactional data
# Format: postgresql://user:password@host:port/database?sslmode=require
# Get this from: https://console.neon.tech
# IMPORTANT: Use the pooled connection string for better performance
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# -----------------------------------------------------------------------------
# Database - Turso (LibSQL/SQLite)
# -----------------------------------------------------------------------------
# REQUIRED: Turso database URL for MINEDU reference data (edge-optimized)
# Format: libsql://your-database.turso.io
# Get this from: https://turso.tech/app
TURSO_DATABASE_URL=libsql://your-database.turso.io

# REQUIRED: Turso authentication token
# Get this from: turso db tokens create <database-name>
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# REQUIRED: Secret key for Better Auth session encryption
# Generate a random string (32+ characters recommended)
# You can use: openssl rand -base64 32
# IMPORTANT: Keep this secret and never commit it to version control
BETTER_AUTH_SECRET=your-random-secret-key-here-min-32-chars

# OPTIONAL: Require email verification for new users
# Default: false
# Set to "true" in production for better security
NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION=false

# -----------------------------------------------------------------------------
# Email - Resend
# -----------------------------------------------------------------------------
# REQUIRED for production: API key from https://resend.com
# Development: Use onboarding@resend.dev (no domain verification needed)
# Production: Use your verified domain (e.g., noreply@tu-dominio.com)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# REQUIRED: Email address that sends the emails
# Development: onboarding@resend.dev (works without domain verification)
# Production: noreply@tu-dominio.com (requires domain verification in Resend)
EMAIL_FROM=onboarding@resend.dev

# -----------------------------------------------------------------------------
# Notes for Production Deployment (Vercel)
# -----------------------------------------------------------------------------
# 1. Set NEXT_PUBLIC_APP_URL to your Vercel domain
# 2. Use Neon's pooled connection string for DATABASE_URL
# 3. Ensure all NEXT_PUBLIC_* variables are set in Vercel dashboard
# 4. Keep DATABASE_URL, TURSO_AUTH_TOKEN as secrets (not exposed to client)
# 5. Turso database should be in the same region as your Vercel deployment
# 6. Set NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION=true in production
# 7. Add RESEND_API_KEY and EMAIL_FROM to Vercel environment variables
